DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_SECONDS=0.8
MAX_FILE_SIZE_MB=10
SESSION_TTL_MINUTES=60
# Comma-separated list of allowed CORS origins (dev: Vite server, prod: your domain)
ALLOWED_ORIGINS=http://localhost:5173
# Model capability flags (for AutoGen):
MODEL_HAS_VISION=false
MODEL_HAS_FUNCTION_CALLING=false
MODEL_HAS_JSON_OUTPUT=true
MODEL_HAS_STRUCTURED_OUTPUT=false
MODEL_FAMILY=v4
